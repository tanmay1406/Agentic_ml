# ==========================================
# SynapseAI Workspace
# (generated during execution)
# ==========================================

workspace/state.json

workspace/models/
workspace/reports/

workspace/**/*.pkl
workspace/**/*.csv
workspace/**/*.json
workspace/**/*.md

# Keep folders even when empty
!workspace/.gitkeep
!workspace/data/.gitkeep
!workspace/data/raw/.gitkeep
!workspace/data/processed/.gitkeep
!workspace/models/.gitkeep
!workspace/reports/.gitkeep

# Ignore temporary agent scripts
workspace/agent_*.py
workspace/temp_agent_script.py

